# Copy to Supabase Dashboard → Edge Functions → Secrets
# Or: supabase secrets set --env-file supabase/.env.example

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Required for create-session (Angular / public form)
PUBLIC_API_KEY=generate-a-long-random-string

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,https://your-production-domain.com

# Rate limits (optional overrides)
RATE_LIMIT_IP_HOUR=20
RATE_LIMIT_PHONE_DAY=3
RATE_LIMIT_EMAIL_DAY=3
RATE_LIMIT_WHATSAPP_PHONE_DAY=5

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-meta-app-secret
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Email via Resend (optional)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=PsicologiaApoyo <noreply@yourdomain.com>
